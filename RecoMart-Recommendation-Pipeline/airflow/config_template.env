# Airflow Configuration Template (rename to .env and configure)

# Airflow home directory
export AIRFLOW_HOME=airflow

# Database backend (default: sqlite)
export AIRFLOW__CORE__DAGS_FOLDER=airflow/dags
export AIRFLOW__CORE__BASE_LOG_FOLDER=airflow/logs
export AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Email configuration (optional)
export AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
export AIRFLOW__SMTP__SMTP_PORT=587
export AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
export AIRFLOW__SMTP__SMTP_PASSWORD=your_password

# RecoMart Data Paths
export RECOMART_PROJECT_ROOT=.
export RECOMART_DATA_PATH=./data
export RECOMART_MODEL_PATH=./mlruns
export RECOMART_LOGS_PATH=./airflow/logs
